# ==========================================
# 🐍 Python Bytecode & Cache (Crucial!)
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/

# ==========================================
# 💾 Local Databases & System States
# ==========================================
# Keeps your actual student database out of GitHub 
# (Highly recommended so you don't overwrite data between computers)
database/*.db
database/*.sqlite3

# ==========================================
# 📁 IDE / Editor Settings (VS Code & PyCharm)
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# 📊 OS Junk Files
# ==========================================
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ==========================================
# 📦 Dynamic Project Folders (Optional)
# ==========================================
# Uncomment these if you want your generated backups 
# and excel/csv reports to remain local only:
# backup/
# exports/